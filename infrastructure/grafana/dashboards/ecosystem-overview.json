{
  "dashboard": {
    "id": null,
    "uid": "trancendos-ecosystem",
    "title": "Trancendos Ecosystem Overview",
    "description": "Real-time monitoring of all 31 services across 6 waves",
    "tags": ["trancendos", "ecosystem", "production"],
    "timezone": "utc",
    "refresh": "10s",
    "time": { "from": "now-1h", "to": "now" },
    "templating": {
      "list": [
        {
          "name": "wave",
          "type": "custom",
          "options": [
            { "text": "All", "value": "" },
            { "text": "Wave 1 - Core", "value": "1" },
            { "text": "Wave 2 - Agents", "value": "2" },
            { "text": "Wave 3 - Infrastructure", "value": "3" },
            { "text": "Wave 4 - Intelligence", "value": "4" },
            { "text": "Wave 5 - Marketplace", "value": "5" },
            { "text": "Wave 6 - Studios", "value": "6" }
          ],
          "current": { "text": "All", "value": "" }
        },
        {
          "name": "service",
          "type": "query",
          "query": "label_values(up, service)",
          "refresh": 2
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "title": "Ecosystem Health",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "count(up == 1)",
            "legendFormat": "Healthy"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 20 },
                { "color": "green", "value": 28 }
              ]
            },
            "max": 31,
            "unit": "short"
          }
        },
        "options": {
          "graphMode": "area",
          "textMode": "value_and_name",
          "orientation": "auto"
        }
      },
      {
        "id": 2,
        "title": "Services Down",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
        "targets": [
          {
            "expr": "count(up == 0) or vector(0)",
            "legendFormat": "Down"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 3,
        "title": "Avg Response Time (P95)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
        "targets": [
          {
            "expr": "avg(histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m])))",
            "legendFormat": "P95 Latency"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 3 }
              ]
            },
            "unit": "s"
          }
        }
      },
      {
        "id": 4,
        "title": "Error Rate (5xx)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{status=~&quot;5..&quot;}[5m])) / sum(rate(http_requests_total[5m])) or vector(0)",
            "legendFormat": "Error Rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 0.01 },
                { "color": "red", "value": 0.05 }
              ]
            },
            "unit": "percentunit"
          }
        }
      },
      {
        "id": 5,
        "title": "Service Status by Wave",
        "type": "table",
        "gridPos": { "h": 10, "w": 12, "x": 0, "y": 4 },
        "targets": [
          {
            "expr": "up",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "includeByName": {
                "service": true,
                "wave": true,
                "category": true,
                "Value": true
              },
              "renameByName": {
                "Value": "Status"
              }
            }
          }
        ],
        "fieldConfig": {
          "overrides": [
            {
              "matcher": { "id": "byName", "options": "Status" },
              "properties": [
                {
                  "id": "mappings",
                  "value": [
                    { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
                    { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } }
                  ]
                }
              ]
            }
          ]
        }
      },
      {
        "id": 6,
        "title": "Request Rate by Service",
        "type": "timeseries",
        "gridPos": { "h": 10, "w": 12, "x": 12, "y": 4 },
        "targets": [
          {
            "expr": "sum(rate(http_requests_total[5m])) by (service)",
            "legendFormat": "{{ service }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "line",
              "lineWidth": 1,
              "fillOpacity": 10,
              "stacking": { "mode": "none" }
            }
          }
        }
      },
      {
        "id": 7,
        "title": "Response Time by Wave",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
        "targets": [
          {
            "expr": "avg(histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))) by (wave)",
            "legendFormat": "Wave {{ wave }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 5
            }
          }
        }
      },
      {
        "id": 8,
        "title": "Memory Usage by Service",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
        "targets": [
          {
            "expr": "process_resident_memory_bytes / 1024 / 1024",
            "legendFormat": "{{ service }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "decmbytes",
            "custom": {
              "drawStyle": "line",
              "lineWidth": 1,
              "fillOpacity": 10
            }
          }
        }
      },
      {
        "id": 9,
        "title": "Circuit Breaker Status",
        "type": "state-timeline",
        "gridPos": { "h": 6, "w": 24, "x": 0, "y": 22 },
        "targets": [
          {
            "expr": "circuit_breaker_state",
            "legendFormat": "{{ service }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "mappings": [
              { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" } } },
              { "type": "value", "options": { "1": { "text": "OPEN", "color": "red" } } },
              { "type": "value", "options": { "2": { "text": "HALF-OPEN", "color": "yellow" } } }
            ]
          }
        }
      },
      {
        "id": 10,
        "title": "Wave 6 Studios — Ista Compliance",
        "type": "bargauge",
        "gridPos": { "h": 6, "w": 12, "x": 0, "y": 28 },
        "targets": [
          {
            "expr": "ista_empathy_mandate_score",
            "legendFormat": "{{ ista }} ({{ service }})"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                { "color": "red", "value": 0 },
                { "color": "yellow", "value": 70 },
                { "color": "green", "value": 90 }
              ]
            },
            "max": 100,
            "unit": "percent"
          }
        },
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient"
        }
      },
      {
        "id": 11,
        "title": "Rate Limit Rejections",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 12, "x": 12, "y": 28 },
        "targets": [
          {
            "expr": "sum(rate(rate_limit_rejected_total[5m])) by (service)",
            "legendFormat": "{{ service }}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 80
            }
          }
        }
      }
    ]
  },
  "overwrite": true
}