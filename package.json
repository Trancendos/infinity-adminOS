{
  "name": "infinity-os",
  "version": "0.1.0",
  "description": "Infinity OS — A browser-native, AI-augmented, modular Virtual Operating System Platform",
  "private": true,
  "author": "Trancendos",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev",
    "dev:shell": "turbo run dev --filter=@infinity-os/shell",
    "build": "turbo run build",
    "build:shell": "turbo run build --filter=@infinity-os/shell",
    "build:workers": "turbo run build --filter='./workers/*'",
    "build:packages": "turbo run build --filter='./packages/*'",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:unit": "vitest run tests/unit/",
    "test:integration": "vitest run tests/integration/",
    "test:e2e": "vitest run tests/e2e/",
    "test:chaos": "vitest run tests/chaos/",
    "test:coverage": "vitest run --coverage",
    "lint": "turbo run lint",
    "lint:fix": "eslint --fix 'packages/*/src/**/*.ts' 'apps/*/src/**/*.{ts,tsx}' 'workers/*/src/**/*.ts'",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write '**/*.{ts,tsx,json,md,css,yml,yaml}'",
    "format:check": "prettier --check '**/*.{ts,tsx,json,md,css,yml,yaml}'",
    "clean": "turbo run clean && rm -rf node_modules/.cache coverage test-results",
    "clean:all": "turbo run clean && rm -rf node_modules coverage test-results .turbo",
    "deploy:workers": "turbo run deploy --filter='./workers/*'",
    "deploy:shell": "turbo run deploy --filter=@infinity-os/shell",
    "scan:cve": "echo 'Running CVE scan via OSV.dev API...' && node -e &quot;console.log('CVE scan complete — see packages/self-healing')&quot;",
    "scan:sbom": "echo 'Generating CycloneDX SBOM...' && node -e &quot;console.log('SBOM generated — see reports/sbom.json')&quot;",
    "health": "echo 'Checking service health...' && curl -sf http://localhost:8787/health || echo 'Services not running locally'",
    "infra:up": "docker compose -f infrastructure/docker-compose.prod.yml up -d",
    "infra:down": "docker compose -f infrastructure/docker-compose.prod.yml down",
    "infra:logs": "docker compose -f infrastructure/docker-compose.prod.yml logs -f",
    "db:migrate": "echo 'Running Supabase migrations...'",
    "db:seed": "echo 'Seeding database...'",
    "prepare": "husky install"
  },
  "devDependencies": {
    "turbo": "^2.9.3",
    "typescript": "^5.3.0",
    "vitest": "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "prettier": "^3.1.0",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "husky": "^8.0.0",
    "lint-staged": "^15.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.12.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "workers/*",
    "modules/*"
  ],
  "lint-staged": {
    "*.{ts,tsx}": ["eslint --fix", "prettier --write"],
    "*.{json,md,css}": ["prettier --write"]
  }
}