# ══════════════════════════════════════════════════════════════
# TRANCENDOS ECOSYSTEM — Production Environment Configuration
# ══════════════════════════════════════════════════════════════
# SECURITY: Never commit this file with real values to git.
# Copy to .env and fill in production secrets.
# ══════════════════════════════════════════════════════════════

# ── Global ──────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info
TZ=UTC

# ── IAM / Authentication ────────────────────────────────────
IAM_ENABLED=true
IAM_JWT_SECRET=CHANGE_ME_TO_A_STRONG_256BIT_SECRET
IAM_JWT_ALGORITHM=HS512
IAM_JWT_EXPIRY=3600
IAM_REFRESH_TOKEN_EXPIRY=86400

# ── Database (Neon PostgreSQL) ──────────────────────────────
NEON_DATABASE_URL=postgresql://user:password@host:5432/trancendos_prod
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
DATABASE_SSL=true

# ── Redis (Session / Cache) ─────────────────────────────────
REDIS_URL=redis://user:password@host:6379/0
REDIS_TLS=true
REDIS_MAX_RETRIES=3

# ── Mesh Networking ─────────────────────────────────────────
MESH_ROUTING_PROTOCOL=static_port
MESH_DISCOVERY_MODE=docker-dns
MESH_TIMEOUT_MS=5000
MESH_RETRY_COUNT=3
MESH_CIRCUIT_BREAKER_THRESHOLD=5

# ── Monitoring (Prometheus / Grafana) ───────────────────────
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
GRAFANA_URL=http://grafana:3100
METRICS_COLLECTION_INTERVAL=15000

# ── Sentinel / Watchdog ─────────────────────────────────────
SENTINEL_HEALTH_INTERVAL=30000
SENTINEL_ALERT_WEBHOOK=https://hooks.slack.com/services/CHANGE_ME
SENTINEL_ESCALATION_EMAIL=ops@trancendos.com

# ── Guardian AI (Security) ──────────────────────────────────
GUARDIAN_FIRE_EYES_ENABLED=true
GUARDIAN_SCAN_INTERVAL=60000
GUARDIAN_NIST_COMPLIANCE=true
GUARDIAN_AGENTIC_SEGREGATION=true
GUARDIAN_PQC_ENABLED=false

# ── Artifactory (Port 3041) ─────────────────────────────────
ARTIFACTORY_PORT=3041
ARTIFACTORY_STORAGE_BACKEND=r2
ARTIFACTORY_R2_BUCKET=trancendos-artifacts
ARTIFACTORY_R2_ACCOUNT_ID=CHANGE_ME
ARTIFACTORY_R2_ACCESS_KEY=CHANGE_ME
ARTIFACTORY_R2_SECRET_KEY=CHANGE_ME
ARTIFACTORY_MAX_UPLOAD_SIZE=524288000
ARTIFACTORY_SBOM_ENABLED=true
ARTIFACTORY_PROVENANCE_ENABLED=true

# ── Keycloak (SSO) ──────────────────────────────────────────
KEYCLOAK_URL=https://auth.trancendos.com
KEYCLOAK_REALM=trancendos
KEYCLOAK_CLIENT_ID=ecosystem
KEYCLOAK_CLIENT_SECRET=CHANGE_ME

# ── External APIs ───────────────────────────────────────────
OPENAI_API_KEY=CHANGE_ME
ANTHROPIC_API_KEY=CHANGE_ME
STRIPE_SECRET_KEY=CHANGE_ME
STRIPE_WEBHOOK_SECRET=CHANGE_ME

# ── TIGA Governance ─────────────────────────────────────────
TIGA_ENFORCEMENT_MODE=audit
TIGA_DAISY_CHAIN_ENABLED=true
TIGA_HASH_ALGORITHM=SHA-512
TIGA_COMPLIANCE_LOG_LEVEL=info

# ── Ista Standard ───────────────────────────────────────────
ISTA_EMPATHY_MANDATE=true
ISTA_ZERO_COST_BIAS=true
ISTA_SARCASTIC_LOGGING=true
ISTA_COMPONENT_ISOLATION=true

# ── 2060 Smart Resilience ───────────────────────────────────
RESILIENCE_CIRCUIT_BREAKER_ENABLED=true
RESILIENCE_CIRCUIT_BREAKER_THRESHOLD=5
RESILIENCE_CIRCUIT_BREAKER_TIMEOUT=30000
RESILIENCE_RATE_LIMIT_WINDOW=60000
RESILIENCE_RATE_LIMIT_MAX=1000
RESILIENCE_TELEMETRY_ENABLED=true
RESILIENCE_EVENT_BUS_ENABLED=true

# ── Docker / Deployment ─────────────────────────────────────
DOCKER_REGISTRY=ghcr.io/trancendos
DOCKER_TAG=latest
COMPOSE_PROJECT_NAME=trancendos

# ── SSL / TLS ───────────────────────────────────────────────
SSL_CERT_PATH=/etc/ssl/certs/trancendos.crt
SSL_KEY_PATH=/etc/ssl/private/trancendos.key
FORCE_HTTPS=true

# ── Logging ─────────────────────────────────────────────────
LOG_FORMAT=json
LOG_DESTINATION=stdout
LOG_RETENTION_DAYS=90