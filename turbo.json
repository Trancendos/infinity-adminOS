{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "globalEnv": ["NETWORK_SEGMENT"],
  "tasks": {
    "build": {
      "dependsOn": [],
      "inputs": ["$TURBO_ROOT/**", "services/$SERVICE_NAME/**"],
      "outputs": ["dist/**", ".next/**", "!.next/cache/**"],
      "env": ["SERVICE_NAME"]
    },
    "dev": {
      "cache": false,
      "persistent": true,
      "env": ["SERVICE_NAME"]
    },
    "test": {
      "dependsOn": [],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "typecheck": {
      "dependsOn": [],
      "outputs": []
    },
    "clean": {
      "cache": false
    }
  }
}
