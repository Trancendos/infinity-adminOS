{
  "name": "@infinity-ecosystem/wellbeing",
  "version": "0.1.0",
  "description": "Wellbeing services nanoservice — Isolated wellbeing and health services",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "echo 'Wellbeing service dev'",
    "build": "echo 'Build wellbeing service'",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "docker:build": "docker build -t infinity-ecosystem/wellbeing .",
