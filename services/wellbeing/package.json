    "health": "curl -sf http://localhost:3055/health || exit 1"
  },
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "segment": "wellbeing",
  "isolation": "strict",
  "apiContracts": [],
  "meshTopology": "isolated"
