# Infinity OS — Frontend Environment Variables
# Copy to .env and configure for your environment

# Backend API URL (leave empty in dev — Vite proxy handles it)
VITE_BACKEND_API_URL=

# WebSocket URL (leave empty in dev — Vite proxy handles it)
VITE_WS_URL=

# App metadata
VITE_APP_NAME=Infinity OS
VITE_APP_VERSION=2.0.0