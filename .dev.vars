# Local Development Environment Variables
# These are placeholder values for local development
# Replace with actual Cloudflare resource IDs for production deployment

# Database
DATABASE_ID=local

# KV Namespace
TRANCENDOS_KV_ID=local

# R2 Bucket
TRANCENDOS_R2_BUCKET=trancendos-bucket

# Queue
TRANCENDOS_QUEUE_ID=local

# Environment
ENVIRONMENT=local
NODE_ENV=development

# API Keys (placeholders)
CLOUDFLARE_API_TOKEN=placeholder_token
CLOUDFLARE_ACCOUNT_ID=placeholder_account_id

# URLs (placeholders for local development)
LIGHTHOUSE_URL=http://localhost:8787
HIVE_URL=http://localhost:8788
INFINITY_ONE_URL=http://localhost:8789