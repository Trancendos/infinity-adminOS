{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "allowImportingTsExtensions": false,
    "baseUrl": ".",
    "paths": {
      "@infinity-ecosystem/creative": ["./services/creative/src/index.ts"],
      "@infinity-ecosystem/financial": ["./services/financial/src/index.ts"],
      "@infinity-ecosystem/knowledge": ["./services/knowledge/src/index.ts"],
      "@infinity-ecosystem/security": ["./services/security/src/index.ts"],
      "@infinity-ecosystem/wellbeing": ["./services/wellbeing/src/index.ts"],
      "@infinity-ecosystem/agent-cornelius-ai": [
        "./agents/cornelius-ai/src/index.ts"
      ],
      "@infinity-ecosystem/agent-guardian-ai": [
        "./agents/guardian-ai/src/index.ts"
      ],
      "@infinity-ecosystem/agent-savania-wellbeing": [
        "./agents/savania-wellbeing/src/index.ts"
      ],
      "@infinity-ecosystem/agent-the-dr-ai": ["./agents/the-dr-ai/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", "build", "coverage"]
}
