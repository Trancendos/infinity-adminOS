{
  "name": "infinity-auth-api",
  "version": "2.0.0",
  "description": "Infinity OS \u2014 Auth API Worker (Cloudflare Workers + D1)",
  "private": true,
  "scripts": {
    "dev": "wrangler dev --env staging",
    "deploy": "wrangler deploy --env production",
    "deploy:staging": "wrangler deploy --env staging",
    "db:migrate:local": "wrangler d1 execute infinity-os-db --local --file=migrations/0001_initial.sql",
    "db:migrate:prod": "wrangler d1 execute infinity-os-db --file=migrations/0001_initial.sql",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260411.1",
    "typescript": "^6.0.2",
    "wrangler": "^4.79.0",
    "vitest": "^4.1.5"
  }
}
