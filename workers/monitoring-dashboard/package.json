{
  "name": "@infinity-os/worker-monitoring-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Infinity OS Monitoring Dashboard — unified observability hub for all platform workers",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
