# ═══════════════════════════════════════════════════════════════
# Infinity OS — Production Environment Configuration
# Trancendos 2060 Standard Compliant
# ═══════════════════════════════════════════════════════════════
# Copy to .env and fill in all REQUIRED values before deployment.
# Generate secrets: python -c "import secrets; print(secrets.token_urlsafe(48))"
# ═══════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────
ENVIRONMENT=production
PORT=8000
WORKERS=4
LOG_LEVEL=WARNING
DEBUG=false

# ── Security (REQUIRED) ─────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=                          # REQUIRED — min 48 chars
JWT_ALGORITHM=HS512
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database (REQUIRED) ─────────────────────────────────────
DB_PASSWORD=                             # REQUIRED — strong password
DATABASE_URL=postgresql+asyncpg://infinity:${DB_PASSWORD}@db:5432/infinity_os
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600
SQL_ECHO=false

# ── CORS (REQUIRED) ─────────────────────────────────────────
CORS_ORIGINS=https://app.infinity-os.dev,https://admin.infinity-os.dev

# ── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=20/minute
RATE_LIMIT_AI=30/minute
MAX_REQUEST_SIZE_MB=50
REQUEST_TIMEOUT_SECONDS=60

# ── LLM Providers (at least one recommended) ────────────────
GROQ_API_KEY=                            # Recommended — fastest
OPENAI_API_KEY=                          # Optional
ANTHROPIC_API_KEY=                       # Optional
HF_API_KEY=                              # Optional
LLM_PROVIDER=groq

# ── C2PA Content Provenance (EU AI Act) ─────────────────────
C2PA_ENABLED=false
C2PA_CERT_PATH=
C2PA_KEY_PATH=

# ── Observability ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=            # e.g., http://otel-collector:4317
OTEL_SERVICE_NAME=infinity-os-api

# ── 2060 Standard ────────────────────────────────────────────
DATA_RESIDENCY_DEFAULT=eu
CONSENT_REQUIRED=true
AI_AUDIT_ENABLED=true
ZERO_COST_MODE=true
FUTURE_PROOF_LEVEL=2060

# ── Kernel Event Bus ─────────────────────────────────────────
EVENT_BUS_BACKEND=redis
EVENT_BUS_REDIS_URL=redis://redis:6379/1
EVENT_BUS_MAX_HISTORY=10000
EVENT_BUS_DEAD_LETTER_MAX=1000

# ── Edge Database (LibSQL/Turso) ─────────────────────────────
LIBSQL_URL=
LIBSQL_AUTH_TOKEN=
LIBSQL_SYNC_INTERVAL=30

# ── Object Storage (S3/MinIO) ───────────────────────────────
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_FILES=infinity-files
S3_BUCKET_BUILDS=infinity-builds
S3_BUCKET_ARTIFACTS=infinity-artifacts

# ── Email ────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@infinity-os.dev

# ── Federation ───────────────────────────────────────────────
FEDERATION_ENABLED=false
# FEDERATION_PEERS=https://peer1.infinity-os.dev,https://peer2.infinity-os.dev