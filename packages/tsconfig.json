{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "allowImportingTsExtensions": false,
    "baseUrl": ".",
    "paths": {
      "@infinity-os/*": ["packages/*/src"],
      "@infinity-ecosystem/*": ["services/*/src"]
    },
    "blacklistedPaths": [
      "../../agents/*",
      "../../services/*",
      "../../workers/*"
    ]
  },
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "../agents",
    "../services",
    "../workers"
  ]
}
